{
  "name": "review-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run db:setup",
    "dev": "NODE_OPTIONS=--no-deprecation next dev",
    "prebuild": "npm run db:setup",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pretest": "npm run db:setup",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:setup": "tsx scripts/setup-db.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
